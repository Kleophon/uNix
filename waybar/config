{
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 0,

    "modules-left": ["niri/workspaces", "custom/platform-profile", "temperature", "memory", "battery"],
    "modules-center": ["clock"],
    "modules-right": ["wireplumber", "idle_inhibitor", "network", "bluetooth", "tray"],

